import pandas as pd
base = '/kaggle/input/datasets/minhbtnguyen/batadal-a-dataset-for-cyber-attack-detection/'

normal_df = pd.read_csv(base + 'training_dataset_1.csv')   # 8761 rows, train IF here
labeled_df = pd.read_csv(base + 'training_dataset_2.csv')  # 4177 rows, evaluate here
test_df = pd.read_csv(base + 'test_dataset.csv')

print("normal_df:", normal_df.shape)
print("labeled_df:", labeled_df.shape)
print("test_df:", test_df.shape)

normal_df.columns = normal_df.columns.str.strip()
labeled_df.columns = labeled_df.columns.str.strip()
test_df.columns = test_df.columns.str.strip()




print(normal_df.columns.tolist())



# Step 3: Separate features and labels
X_train = normal_df.drop(columns=['ATT_FLAG'], errors='ignore')
X_eval = labeled_df.drop(columns=['ATT_FLAG'])
y_eval = labeled_df['ATT_FLAG']

print("X_train shape:", X_train.shape)
print("X_eval shape:", X_eval.shape)
print("y_eval distribution:\n", y_eval.value_counts())
print("\nNulls in X_train:", X_train.isnull().sum().sum())
print("Nulls in X_eval:", X_eval.isnull().sum().sum())


print(normal_df.index)
print(normal_df.shape)
print(normal_df.columns.tolist())


from sklearn.preprocessing import StandardScaler
from sklearn.ensemble import IsolationForest

scaler = StandardScaler()
X_train_scaled = scaler.fit_transform(X_train)
X_eval_scaled = scaler.transform(X_eval)

# Train Isolation Forest
model = IsolationForest(n_estimators=100, contamination=0.12, random_state=42)
model.fit(X_train_scaled)

print("Model trained.")


from sklearn.metrics import classification_report, f1_score

# Predict (-1 = anomaly, 1 = normal) → convert to (1 = anomaly, 0 = normal)
y_pred_raw = model.predict(X_eval_scaled)
y_pred = (y_pred_raw == -1).astype(int)

# Evaluate
print(classification_report(y_eval, y_pred, target_names=['Normal', 'Attack']))
print("F1 Score (Attack class):", f1_score(y_eval, y_pred))
